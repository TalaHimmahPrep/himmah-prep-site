# Formspree endpoint that catches consultation / main-site lead submissions.
# Sign up at https://formspree.io, create a form, and copy the URL it gives you.
# Connect Formspree's Google Sheets plugin to also pipe submissions to a sheet.
FORMSPREE_ENDPOINT=https://formspree.io/f/REPLACE_ME

# Optional: separate Formspree endpoint for SAT bootcamp enrollments.
# When set, submissions with source starting "sat-bootcamp" are routed here
# instead of FORMSPREE_ENDPOINT. When unset, all submissions go to
# FORMSPREE_ENDPOINT (subject line differentiates them).
FORMSPREE_BOOTCAMP_ENDPOINT=https://formspree.io/f/REPLACE_ME

# Zapier webhook for the consultation auto-confirmation email (main form +
# popup). Bootcamp enrollments do NOT use this — they have their own webhook.
ZAPIER_LEAD_WEBHOOK=https://hooks.zapier.com/hooks/catch/REPLACE_ME

# Zapier webhook for the SAT bootcamp welcome-pack email. Fires only for
# submissions with source starting "sat-bootcamp". When unset, no Zapier email
# goes out for bootcamp enrollments (Formspree still has the lead).
ZAPIER_BOOTCAMP_WEBHOOK=https://hooks.zapier.com/hooks/catch/REPLACE_ME
